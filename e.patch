+        }
+        if (SettingsStatus.messageLoggerDeletes) {
+            addPreference(category, helper.switchPreference(
+                    Strings.MESSAGE_LOGGER_DELETES,
+                    Strings.MESSAGE_LOGGER_DELETES_DESC,
+                    Settings.MESSAGE_LOGGER_DELETES
